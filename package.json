{
  "name": "bike-rental-backend",
  "version": "1.0.0",
  "description": "MERN Bike Rental Booking Backend API",
  "main": "src/server.js",
  "scripts": {
    "start":      "node src/server.js",
    "dev":        "nodemon src/server.js",
    "seed":       "node src/utils/seeder.js",
    "test":       "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:cover": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment":       "node",
    "testMatch":             ["**/tests/**/*.test.js"],
    "setupFilesAfterEnv":    ["./tests/setup.js"],
    "testTimeout":           30000,
    "verbose":               true
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.8",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
